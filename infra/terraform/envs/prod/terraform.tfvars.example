# cp terraform.tfvars.example terraform.tfvars 후 필요 시 수정
project     = "manyak"
environment = "prod"
region      = "ap-northeast-2"

# GitHub OIDC provider 를 이 구성에서 생성할지 여부.
# 계정에 token.actions.githubusercontent.com provider 가 이미 있으면 false 로 둔다.
create_github_oidc_provider = true

# ElastiCache Redis 생성 여부 (KNK-239)
enable_redis = true

# Cloudflare API 토큰 (Edit zone DNS 권한). ACM 검증·api.manyak.app 레코드 생성용.
# Cloudflare 대시보드 > My Profile > API Tokens 에서 발급. 실제 값은 커밋 금지.
cloudflare_api_token = "cf-xxxxxxxxxxxxxxxxxxxx"
