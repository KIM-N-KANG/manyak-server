#!/bin/bash
set -euxo pipefail

# Docker + jq 설치 (Amazon Linux 2023). jq 는 Secrets Manager JSON 파싱에 사용.
dnf update -y
dnf install -y docker jq
systemctl enable --now docker

# docker compose v2 플러그인 설치
mkdir -p /usr/local/lib/docker/cli-plugins
ARCH="$(uname -m)"
curl -SL "https://github.com/docker/compose/releases/latest/download/docker-compose-linux-$${ARCH}" \
  -o /usr/local/lib/docker/cli-plugins/docker-compose
chmod +x /usr/local/lib/docker/cli-plugins/docker-compose

# 앱 디렉터리 + compose 파일 기록
mkdir -p /opt/manyak
cat > /opt/manyak/docker-compose.yml <<'COMPOSE'
${compose_content}
COMPOSE

# 배포/기동 스크립트 생성(최초 부팅·이후 CI 의 SSM Run Command 에서 공용 사용).
# 매 실행마다 Secrets Manager 를 재조회해 .env 를 갱신하므로, apply 후 시크릿 값을 바꿔도 재배포로 반영된다.
cat > /opt/manyak/deploy.sh <<'DEPLOY'
#!/bin/bash
set -euxo pipefail

# 배포 직렬화: server·ai 워크플로는 서로 다른 레포라 GitHub Actions 의 concurrency(레포 내부 한정)로는
# 동시 실행을 막지 못한다. 두 워크플로가 같은 EC2 의 이 스크립트를 동시에 SSM 으로 호출하면 .env 재작성·
# compose 조작이 경합하므로, EC2 단에서 flock 으로 모든 호출을 직렬화한다(최대 300s 대기 후 포기).
exec 200>/var/lock/manyak-deploy.lock
flock -w 300 200 || { echo "deploy lock 획득 실패(300s) — 다른 배포 진행 중"; exit 1; }

cd /opt/manyak

# 시크릿 조회 + .env 갱신. 값이 cloud-init/SSM 로그에 평문으로 남지 않도록 이 구간만 xtrace(-x)를 끈다.
set +x
DB_SECRET_JSON="$(aws secretsmanager get-secret-value --region ${aws_region} --secret-id ${db_secret_arn} --query SecretString --output text)"
DB_USERNAME="$(echo "$DB_SECRET_JSON" | jq -r '.username')"
DB_PASSWORD="$(echo "$DB_SECRET_JSON" | jq -r '.password')"
APP_SECRET_JSON="$(aws secretsmanager get-secret-value --region ${aws_region} --secret-id ${app_secret_arn} --query SecretString --output text)"
SERVER_SENTRY_DSN="$(echo "$APP_SECRET_JSON" | jq -r '.SERVER_SENTRY_DSN // .SENTRY_DSN // ""')"
AI_SENTRY_DSN="$(echo "$APP_SECRET_JSON" | jq -r '.AI_SENTRY_DSN // ""')"
SLACK_WEBHOOK="$(echo "$APP_SECRET_JSON" | jq -r '.MANYAK_SLACK_FEEDBACK_WEBHOOK_URL // ""')"
PEPPER="$(echo "$APP_SECRET_JSON" | jq -r '.MANYAK_ANALYTICS_ANONYMOUS_ID_PEPPER // ""')"
DEEPSEEK_API_KEY="$(echo "$APP_SECRET_JSON" | jq -r '.DEEPSEEK_API_KEY // ""')"

# 이미지 좌표 결정. server·ai 워크플로는 각각 자기 서비스의 OVERRIDE 만 보낸다
# (server=SERVER_IMAGE_OVERRIDE, ai=AI_IMAGE_OVERRIDE). 한 서비스만 배포할 때 다른 서비스의 핀 고정
# 이미지가 :latest 로 덮이지 않도록, override 가 없으면 기존 .env 값을 보존하고 그것도 없으면 terraform 기본값을 쓴다.
CUR_SERVER_IMAGE=""
CUR_AI_IMAGE=""
if [ -f /opt/manyak/.env ]; then
  CUR_SERVER_IMAGE="$(sed -n 's/^SERVER_IMAGE=//p' /opt/manyak/.env)"
  CUR_AI_IMAGE="$(sed -n 's/^AI_IMAGE=//p' /opt/manyak/.env)"
fi
SERVER_IMAGE="$${SERVER_IMAGE_OVERRIDE:-$${CUR_SERVER_IMAGE:-${server_image}}}"
AI_IMAGE="$${AI_IMAGE_OVERRIDE:-$${CUR_AI_IMAGE:-${ai_image}}}"

umask 077
{
  echo "SERVER_IMAGE=$SERVER_IMAGE"
  echo "AI_IMAGE=$AI_IMAGE"
  echo "MANYAK_DB_URL=jdbc:postgresql://${db_address}:${db_port}/${db_name}"
  echo "MANYAK_DB_USERNAME=$DB_USERNAME"
  echo "MANYAK_DB_PASSWORD=$DB_PASSWORD"
  echo "SENTRY_DSN=$SERVER_SENTRY_DSN"
  echo "AI_SENTRY_DSN=$AI_SENTRY_DSN"
  echo "SENTRY_ENVIRONMENT=${environment}"
  echo "MANYAK_SLACK_FEEDBACK_WEBHOOK_URL=$SLACK_WEBHOOK"
  echo "MANYAK_ANALYTICS_ANONYMOUS_ID_PEPPER=$PEPPER"
  echo "DEEPSEEK_API_KEY=$DEEPSEEK_API_KEY"
} > /opt/manyak/.env
chmod 600 /opt/manyak/.env
# docker compose v2 의 env_file 은 값 안의 $ 를 변수 보간으로 해석하므로 .env 의 $ 를 $$ 로 이스케이프한다.
# (RDS 자동생성 비밀번호에 $ 가 들어가면 보간으로 잘려 DB 인증 실패 → 헬스체크 실패로만 드러남)
sed -i 's/\$/$$/g' /opt/manyak/.env
set -x

# ECR 재로그인(토큰 12h 만료)
aws ecr get-login-password --region ${aws_region} \
  | docker login --username AWS --password-stdin ${ecr_registry_url}

# 무엇을 (재)기동할지 결정한다.
# - AI_IMAGE_OVERRIDE 가 오면 ai 만 (재)기동(manyak-ai 워크플로 트리거).
# - SERVER_IMAGE_OVERRIDE 가 오면 server 만 (재)기동(manyak-server 워크플로 트리거).
# - 둘 다 없으면(최초 부팅) server 를 기동하고, ai 는 이미지가 ECR 에 있으면 함께 기동(없으면 graceful 스킵).
#   → manyak-ai 이미지가 아직 없어도 server 배포가 깨지지 않게 한다(순서 의존 제거).
# pull/up 실패는 CI 의 SSM 상태 게이트·스모크가 감지하도록 || true 없이 전파한다.
if [ -n "$${AI_IMAGE_OVERRIDE:-}" ]; then
  docker compose pull ai
  docker compose up -d ai
elif [ -n "$${SERVER_IMAGE_OVERRIDE:-}" ]; then
  docker compose pull server
  docker compose up -d server
else
  docker compose pull server
  docker compose up -d server
  if docker compose pull ai; then
    docker compose up -d ai
  else
    echo "manyak-ai 이미지 미존재 — ai 기동 건너뜀(이후 manyak-ai 배포 시 기동)"
  fi
fi
docker image prune -f || true
DEPLOY
chmod +x /opt/manyak/deploy.sh

# 최초 기동 (set -e 로 부팅이 중단되지 않도록 실패 무시; 이후 재배포는 CI 가 deploy.sh 를 SSM 으로 재실행)
bash /opt/manyak/deploy.sh || true
