@baseUrl = http://localhost:8080

# 스토리라인 평가(좋아요/나빠요) API 수동 검증
#
# 사전 준비
#   1) docker compose up -d  (Postgres·AI 서버 기동)
#   2) ./gradlew bootRun     (백엔드 8080 기동, MANYAK_AI_BASE_URL은 scheme 포함)
#
# 실행 순서
#   위에서부터 순서대로 실행합니다. 1~2번이 storylineId 전역 변수를 채우고,
#   이후 평가/취소/에러 케이스가 그 값을 사용합니다.
#   마지막 요청만 흐름과 무관하게 실제 DB의 임의 storylineId로 바꿔 직접 눌러볼 수 있습니다.

### -1. 백엔드 서버 상태 확인
# 이 요청이 연결되지 않으면 백엔드가 8080 포트에서 실행 중이 아닙니다.
GET {{baseUrl}}/actuator/health
Accept: application/json

### 1. 평가 대상 스토리라인 생성 (AI 서버 필요)
# 응답의 storylines[0].id를 평가 대상으로 전역 저장합니다.
POST {{baseUrl}}/api/v1/stories/simple/storylines
Content-Type: application/json
Accept: application/json

{
  "customTags": [
    { "name": "판타지", "category": "GENRE" },
    { "name": "기억상실", "category": "PROTAGONIST" },
    { "name": "비밀스러운 조력자", "category": "SUPPORTING_CHARACTER" }
  ]
}

> {%
    client.test("스토리라인 생성 응답이 정상이다", () => {
        client.assert(response.status === 201, `201이 아닙니다. actual=${response.status}`);
        client.assert(Array.isArray(response.body.storylines) && response.body.storylines.length === 3,
            `storylines가 3개가 아닙니다. actual=${JSON.stringify(response.body.storylines)}`);
    });
    if (response.body.storylines && response.body.storylines.length > 0) {
        client.global.set("storylineId", response.body.storylines[0].id);
    }
%}

### 2. 평가 설정 — GOOD
# 1번을 먼저 실행해야 storylineId가 설정됩니다.
PUT {{baseUrl}}/api/v1/stories/simple/storylines/{{storylineId}}/rating
Content-Type: application/json
Accept: application/json

{ "rating": "GOOD" }

> {%
    client.test("최초 평가가 200으로 저장된다", () => {
        client.assert(response.status === 200, `200이 아닙니다. actual=${response.status}`);
    });
    const b = response.body;
    client.test("응답에 storylineId와 rating이 담긴다", () => {
        client.assert(String(b.storylineId) === String(client.global.get("storylineId")),
            `storylineId가 다릅니다. actual=${b.storylineId}`);
        client.assert(b.rating === "GOOD", `rating이 GOOD이 아닙니다. actual=${b.rating}`);
    });
%}

### 3. 평가 변경 — BAD (대상당 1개, 값만 갱신)
PUT {{baseUrl}}/api/v1/stories/simple/storylines/{{storylineId}}/rating
Content-Type: application/json
Accept: application/json

{ "rating": "BAD" }

> {%
    client.test("재평가 시 값이 갱신된다", () => {
        client.assert(response.status === 200, `200이 아닙니다. actual=${response.status}`);
        client.assert(response.body.rating === "BAD", `rating이 BAD로 갱신되지 않았습니다. actual=${response.body.rating}`);
    });
%}

### 4. 평가 취소 — 204
DELETE {{baseUrl}}/api/v1/stories/simple/storylines/{{storylineId}}/rating
Accept: application/json

> {%
    client.test("평가 취소가 204로 응답한다", () => {
        client.assert(response.status === 204, `204가 아닙니다. actual=${response.status}`);
    });
%}

### 5. 평가가 없는 스토리라인 취소 — 멱등 204
# 4번에서 이미 삭제됐으므로 다시 취소해도 204입니다.
DELETE {{baseUrl}}/api/v1/stories/simple/storylines/{{storylineId}}/rating
Accept: application/json

> {%
    client.test("평가가 없어도 취소는 멱등하게 204다", () => {
        client.assert(response.status === 204, `204가 아닙니다. actual=${response.status}`);
    });
%}

### 6. 에러 — 존재하지 않는 스토리라인 평가(404)
PUT {{baseUrl}}/api/v1/stories/simple/storylines/999999999/rating
Content-Type: application/json
Accept: application/json

{ "rating": "GOOD" }

> {%
    client.test("없는 스토리라인 평가는 404다", () => {
        client.assert(response.status === 404, `404가 아닙니다. actual=${response.status}`);
        client.assert(response.body.message === "스토리라인을 찾을 수 없습니다.",
            `메시지가 기대와 다릅니다. actual=${response.body.message}`);
    });
%}

### 7. 에러 — 존재하지 않는 스토리라인 취소(404)
DELETE {{baseUrl}}/api/v1/stories/simple/storylines/999999999/rating
Accept: application/json

> {%
    client.test("없는 스토리라인 취소는 404다", () => {
        client.assert(response.status === 404, `404가 아닙니다. actual=${response.status}`);
        client.assert(response.body.message === "스토리라인을 찾을 수 없습니다.",
            `메시지가 기대와 다릅니다. actual=${response.body.message}`);
    });
%}

### 8. 에러 — 잘못된 평가 값(400)
PUT {{baseUrl}}/api/v1/stories/simple/storylines/{{storylineId}}/rating
Content-Type: application/json
Accept: application/json

{ "rating": "AWESOME" }

> {%
    client.test("허용되지 않은 rating 값은 400이다", () => {
        client.assert(response.status === 400, `400이 아닙니다. actual=${response.status}`);
    });
%}

### 9. 에러 — 평가 값 누락(400)
PUT {{baseUrl}}/api/v1/stories/simple/storylines/{{storylineId}}/rating
Content-Type: application/json
Accept: application/json

{ }

> {%
    client.test("rating 누락은 400이다", () => {
        client.assert(response.status === 400, `400이 아닙니다. actual=${response.status}`);
    });
%}

### 10. 자유 실행 — 실제 DB의 storylineId로 직접 평가
# 위 흐름과 무관하게, 본인이 알고 있는 실제 storyline ID로 바꿔 눌러보세요.
# (조회 엔드포인트는 없습니다. 평가 결과 확인은 DB 또는 위 PUT 응답으로 합니다.)
PUT {{baseUrl}}/api/v1/stories/simple/storylines/1/rating
Content-Type: application/json
Accept: application/json

{ "rating": "BAD" }
